apiVersion: v1
kind: Pod
metadata:
  name: "reranker-{{ .InstanceSlug }}"
  labels:
    ai-services.io/template: "{{ .TemplateID }}"
  annotations:
    io.podman.annotations.ulimit: "nofile=134217728:134217728,memlock=-1:-1"
    io.podman.annotations.userns: "keep-id"
    run.oci.keep_original_groups: "1"
    ai-services.io/reranker--spyre-cards: "1"
spec:
  restartPolicy: always
  volumes:
    - name: dshm
      emptyDir:
        medium: Memory
        sizeLimit: 64Gi
    - name: models
      hostPath:
        path: "{{ .BaseDir }}/models"
        type: Directory
  containers:
    - name: reranker
      image: "{{ .Values.image }}"
      command: ["/bin/bash"]
      args:
        - "-c"
        - |
          /opt/app-root/spyre_entrypoint.sh \
          --model ${VLLM_MODEL_PATH} \
          -tp ${AIU_WORLD_SIZE} \
          --served-model-name {{ .Values.model }} --port 8002
      livenessProbe:
        httpGet:
          path: /health
          port: 8002
        initialDelaySeconds: 120
        periodSeconds: 30
        timeoutSeconds: 5
        failureThreshold: 3
      env:
        - name: VLLM_MODEL_PATH
          value: "/models/{{ .Values.model }}"
        - name: AIU_WORLD_SIZE
          value: "1"
        - name: VLLM_SPYRE_USE_CHUNKED_PREFILL
          value: "0"
        - name: VLLM_SPYRE_WARMUP_BATCH_SIZES
          value: "4"
        - name: VLLM_SPYRE_WARMUP_PROMPT_LENS
          value: "1024"
        - name: MASTER_PORT
          value: "12356"
        {{- /* Check if .env.reranker exists and is a non-empty map */}}
        {{- with .env.reranker }}
          {{- /* If it does, '.' (dot) is now scoped to .env.reranker */}}
          {{- range $k, $v := . }}
        - name: {{ $k }}
          value: "{{ $v }}"
          {{- end }}
        {{- end }}
      resources:
        requests:
          podman.io/device=/dev/vfio: 1
          memory: "5Gi"
        limits:
          memory: "5Gi"
      ports:
        - containerPort: 8002
      volumeMounts:
        - mountPath: /models:z
          name: models
          readOnly: true
        - mountPath: /dev/shm
          name: dshm
