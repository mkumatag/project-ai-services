apiVersion: v1
kind: Pod
metadata:
  name: "hello-world-{{ .InstanceSlug }}"
  labels:
    ai-services.io/template: "{{ .TemplateID }}"
  annotations:
    ai-services.io/routes: "8000:hello-world-{{ .InstanceSlug }}:ui"
    # ai-services.io/ports: "{{ .Values.hello_world.port }}:8000"  # Uncomment to expose port directly (bypasses Caddy)
spec:
  restartPolicy: always
  containers:
    - name: hello-world
      image: "{{ .Values.hello_world.image }}"
      command:
        - "/var/venv/bin/python"
        - "-m"
        - "uvicorn"
        - "app:app"
        - "--host"
        - "0.0.0.0"
        - "--port"
        - "8000"
        - "--loop"
        - "uvloop"
        - "--http"
        - "httptools"
      env:
        - name: PORT
          value: "8000"
        - name: LLM_ENDPOINT
          value: "http://{{ .Values.llm.host }}:{{ .Values.llm.port }}"
        - name: LLM_MODEL
          value: "{{ .Values.llm.model }}"
        - name: LOG_LEVEL
          value: "{{ .Values.hello_world.log_level }}"
        - name: MAX_TOKENS
          value: "{{ .Values.hello_world.max_tokens }}"
        - name: TEMPERATURE
          value: "{{ .Values.hello_world.temperature }}"
      ports:
        - containerPort: 8000
          protocol: TCP
      livenessProbe:
        httpGet:
          path: /health
          port: 8000
        initialDelaySeconds: 10
        periodSeconds: 30
        timeoutSeconds: 5
        failureThreshold: 3
      resources:
        requests:
          memory: "512Mi"
        limits:
          memory: "512Mi"
